{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "env": {
    "DATA_DIR": "/tmp/academic-bridge-data"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/blog/(.*)", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/admin", "destination": "/admin.html" }
  ]
}
